#!/usr/bin/env bash
#
# claudim — launch Claude Code against the Jota AI Gateway (free-claude-code proxy)
# over Tailscale. Install once (see scripts/install-claudim.sh), then run `claudim`
# from any directory like you would `claude`.
#
#   claudim                 # interactive Claude Code, pointed at the gateway
#   claudim "fix this bug"  # all args pass straight through to claude
#   claudim upgrade         # update claudim itself (re-runs the installer)
#   claudim models          # list delegate aliases + their strengths
#   claudim -p --model deepseek-v4-pro "task"   # delegate: cheap model, returns
#                                               # the answer on stdout
#   claudim -p --unrestricted --model deepseek-v4-flash "task"
#                             # delegate that can run gcloud / network / file
#                             # writes (bypasses Claude Code permission prompts,
#                             # which -p can't answer). Opt-in: only when the
#                             # task needs it. Default is sandboxed (auto).
#   CLAUDIM_TMUX=1 claudim -p --model kimi-k2.7-code "task"
#                             # run the delegate inside a tmux window you can
#                             # watch AND interact with. If you're inside tmux,
#                             # it opens in YOUR session; else in a detached
#                             # session `claudim` (tmux attach -t claudim). -p only.
#
# `--model <alias>` is rewritten to the gateway's no-thinking model id so that
# `claude -p` delegates return non-empty output (reasoning backends otherwise
# stream an unsigned `thinking` block that Claude Code -p discards). A full
# routed id (contains "/") or a Claude alias (haiku/sonnet/opus) is passed
# through unchanged. See `claudim models`.
#
# `--unrestricted` (or CLAUDIM_BYPASS=1) injects `--dangerously-skip-permissions`
# so a -p delegate can run gcloud/GCP/network/file-write commands that the
# default `auto` permission mode would deny non-interactively. Off by default.
# `--tmux` (or CLAUDIM_TMUX=1) wraps a -p delegate in a tmux window for live
# observation. Both are claudim-only flags (stripped before reaching claude).
#
# Requirements on the dev machine:
#   - Tailscale: installed and logged in to the company tailnet (jota.ai),
#     and your user permitted by the tailnet ACL to reach tag:fcc-proxy.
#   - Claude Code: `npm install -g @anthropic-ai/claude-code`.
#
# Override any default with an env var (e.g. in your shell rc):
#   CLAUDIM_HOST      proxy MagicDNS host       (default: fcc-proxy)
#   CLAUDIM_TAILNET   tailnet DNS suffix        (default: tail576af6.ts.net)
#   CLAUDIM_PORT      proxy port                (default: 8082)
#   CLAUDIM_TOKEN     proxy auth token          (default: freecc)
#   CLAUDIM_WAIT      seconds to wait for proxy (default: 30)
#   CLAUDIM_BYPASS    1 = inject --dangerously-skip-permissions (let -p delegate
#                     run gcloud/network/file-writes; off by default)
#   CLAUDIM_TMUX      1 = open each -p delegate in a tmux window (your current
#                     session if inside tmux, else detached session `claudim`;
#                     needs tmux on PATH; falls back to inline if absent)
#
set -euo pipefail

HOST="${CLAUDIM_HOST:-fcc-proxy}"
TAILNET="${CLAUDIM_TAILNET:-tail576af6.ts.net}"
PORT="${CLAUDIM_PORT:-8082}"
TOKEN="${CLAUDIM_TOKEN:-freecc}"
WAIT="${CLAUDIM_WAIT:-30}"

FQDN="${HOST}.${TAILNET}"
BASE_URL="http://${FQDN}:${PORT}"

say()  { echo "[claudim] $*" >&2; }
die()  { echo "[claudim] error: $*" >&2; exit 1; }

# Map a friendly delegate alias to the gateway's no-thinking model id.
# The no-thinking variant is MANDATORY for `claude -p` delegates: reasoning
# backends otherwise stream a `thinking` block with an empty signature, which
# Claude Code in -p/SDK mode treats as an invalid turn and discards — yielding
# empty stdout even though the text block was sent. The `claude-3-freecc-no-
# thinking/` prefix both tells Claude Code the model doesn't support thinking
# (no signature expected) and tells the gateway to disable thinking upstream.
# Values that already look like a routed id (contain "/") or a Claude alias
# (haiku/sonnet/opus) are passed through unchanged.
resolve_model_alias() {
  case "$1" in
    deepseek-v4-pro)   printf 'claude-3-freecc-no-thinking/open_router/deepseek/deepseek-v4-pro' ;;
    kimi-k2.7-code)    printf 'claude-3-freecc-no-thinking/open_router/moonshotai/kimi-k2.7-code' ;;
    deepseek-v4-flash) printf 'claude-3-freecc-no-thinking/open_router/deepseek/deepseek-v4-flash' ;;
    glm-5.2)           printf 'claude-3-freecc-no-thinking/open_router/z-ai/glm-5.2' ;;
    minimax-m3)        printf 'claude-3-freecc-no-thinking/open_router/minimax/minimax-m3' ;;
    mistral-small)     printf 'claude-3-freecc-no-thinking/open_router/mistralai/mistral-small-3.2-24b-instruct' ;;
    ministral-8b)      printf 'claude-3-freecc-no-thinking/open_router/mistralai/ministral-8b-2512' ;;
    codestral)         printf 'claude-3-freecc-no-thinking/open_router/mistralai/codestral-2508' ;;
    *) printf '%s' "$1" ;;
  esac
}

# Run a `claude -p` delegate inside a tmux PANE so the user watches it live
# AND can interact with it (approve prompts, type instructions).
#
# Layout (inside the caller's tmux session): the orchestrator pane keeps the
# LEFT HALF at full height; delegates stack vertically in the right half, one
# equal-height slice each. Achieved with tmux's built-in `main-vertical`
# layout (main-pane-width 50%), re-applied after every spawn so N delegates
# always split the right column into N equal slices. When a delegate finishes
# its pane closes and the layout re-balances.
#
# Outside tmux there is no pane to split, so delegates go to a window in a
# detached session named "claudim" (tmux attach -t claudim from another
# terminal).
#
# stdout is teed to a log and returned on claudim's stdout so the orchestrator
# captures it exactly like the inline path. stderr goes to a separate file
# (not merged) so --output-format json stays parseable. Blocks until the
# delegate exits, then removes the pane/window.
#
# Env is passed explicitly in the pane command (env VAR=... claude ...) so a
# pre-existing tmux server with a different environment can't lose the gateway
# exports claudim set above.
run_in_tmux() {
  local in_session=0
  local sess=""
  if [ -n "${TMUX:-}" ]; then
    in_session=1
    sess="$(tmux display-message -p '#S' 2>/dev/null)"
  fi
  if [ -z "${sess}" ]; then
    in_session=0
    sess="claudim"
    tmux has-session -t "$sess" 2>/dev/null || tmux new-session -d -s "$sess"
  fi

  local out="/tmp/claudim-$$.log"
  local err="/tmp/claudim-err-$$.log"
  local done="/tmp/claudim-done-$$"
  # Title carries the delegate model (last path segment) so panes/windows are
  # tellable apart; PID suffix keeps parallel delegates unique.
  local model="" _prev=""
  for _a in "$@"; do
    case "$_prev" in --model) model="$_a" ;; esac
    case "$_a" in --model=*) model="${_a#--model=}" ;; esac
    _prev="$_a"
  done
  model="${model##*/}"
  local title="${model:-del}-$$"

  # Shell-quote every claude arg so tmux's shell parses them verbatim.
  local cmd=""
  local _a
  for _a in "$@"; do cmd+=$(printf '%q ' "$_a"); done

  # Pass the gateway env explicitly (tmux server may not share claudim's env).
  local envp="env"
  envp+=" PATH=$(printf '%q' "$PATH")"
  envp+=" ANTHROPIC_BASE_URL=$(printf '%q' "$ANTHROPIC_BASE_URL")"
  envp+=" ANTHROPIC_AUTH_TOKEN=$(printf '%q' "$ANTHROPIC_AUTH_TOKEN")"
  envp+=" CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=$(printf '%q' "$CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY")"
  envp+=" CLAUDE_CODE_AUTO_COMPACT_WINDOW=$(printf '%q' "$CLAUDE_CODE_AUTO_COMPACT_WINDOW")"

  local shellcmd="$envp claude $cmd 2>$(printf '%q' "$err") | tee $(printf '%q' "$out"); printf 1 > $(printf '%q' "$done")"

  rm -f "$done"
  if [ "$in_session" -eq 1 ]; then
    # Split inside the ORCHESTRATOR's window. The first delegate splits the
    # orchestrator pane horizontally (left|right); the next ones keep
    # splitting, then `main-vertical` re-lays everything out: pane 0 (the
    # orchestrator) becomes the left column at 50% width and full height, and
    # every delegate pane becomes an equal-height slice in the right column.
    local orig_win new_pane
    orig_win="$(tmux display-message -p '#{window_id}' 2>/dev/null)"
    new_pane="$(tmux split-window -d -h -t "$orig_win" -P -F '#{pane_id}' "$shellcmd" 2>/dev/null)"
    [ -n "$new_pane" ] && tmux select-pane -t "$new_pane" -T "$title" 2>/dev/null || true
    tmux select-pane -t "$orig_win.0" -T "orchestrator" 2>/dev/null || true
    tmux set-window-option -t "$orig_win" pane-border-status top 2>/dev/null || true
    tmux set-window-option -t "$orig_win" main-pane-width '50%' 2>/dev/null || true
    tmux select-layout -t "$orig_win" main-vertical 2>/dev/null || true
    # Re-balance once more when the pane count changes on exit (handled below
    # after the sentinel, since the dying pane auto-closes).
  else
    tmux new-window -d -t "$sess" -n "$title" "$shellcmd"
  fi

  # Block until the delegate finishes (sentinel file), regardless of
  # remain-on-exit. Then surface stdout and tear down the pane/window.
  while [ ! -f "$done" ]; do sleep 0.5; done
  rm -f "$done"
  cat "$out" 2>/dev/null
  rm -f "$out" "$err"
  if [ "$in_session" -eq 1 ]; then
    # The delegate pane closed itself when its command exited; re-balance the
    # remaining delegate slices (no-op if the orchestrator pane is alone).
    tmux select-layout -t "$orig_win" main-vertical 2>/dev/null || true
  else
    tmux kill-window -t "$sess:$title" 2>/dev/null || true
  fi
}

# Self-update of the claudim launcher ONLY, and the `models` cheat-sheet. Both are
# intercepted as the bare first arg so they never reach `claude`. Run before the
# claude/tailscale checks so they work regardless.
case "${1:-}" in
  upgrade|--upgrade|self-update|--self-update)
    INSTALLER="${CLAUDIM_INSTALLER:-https://raw.githubusercontent.com/usejota/agentic-model-gateway/main/scripts/install-claudim.sh}"
    say "upgrading claudim from ${INSTALLER}"
    if command -v curl >/dev/null 2>&1; then
      exec sh -c "curl -fsSL '${INSTALLER}' | sh"
    elif command -v wget >/dev/null 2>&1; then
      exec sh -c "wget -qO- '${INSTALLER}' | sh"
    fi
    die "need curl or wget to upgrade claudim"
    ;;
  models|--models)
    if [ "${2:-}" = "--all" ] || [ "${2:-}" = "all" ]; then
      # Live list of every NON-AMERICAN no-thinking model the gateway offers.
      # Cost-driven: excludes the expensive US closed labs that charge premium
      # per-token (plus the US aggregator's house models). Everything else is
      # allowed — Chinese (deepseek/qwen/kimi/glm/minimax/...), Mistral (FR),
      # Cohere (CA), AI21 (IL), Arcee (UK), Sakana (JP), Upstage (KR), and
      # open-weight Llama + its fine-tunes (serving revenue doesn't reach a US
      # closed lab per call). Always reflects the current gateway.
      curl -s -m 10 "${BASE_URL}/v1/models" -H "x-api-key: ${TOKEN}" 2>/dev/null | python3 -c '
import sys, json
from collections import defaultdict
US_CLOSED = {"openai", "anthropic", "google", "x-ai", "amazon", "nvidia",
             "ibm-granite", "liquid", "rekaai", "relace", "openrouter"}
try:
    d = json.load(sys.stdin)
except Exception as e:
    sys.exit(f"could not parse /v1/models: {e} (gateway reachable? tailscale up?)")
g = defaultdict(list)
for m in d.get("data", []):
    i = m.get("id", "")
    if not i.startswith("claude-3-freecc-no-thinking/"):
        continue
    parts = i.split("/")
    # Format: claude-3-freecc-no-thinking/<route>/<vendor>/<model...>
    # vendor is the segment right after the route (e.g. open_router).
    if len(parts) < 4:
        continue
    vendor = parts[2].lstrip("~")
    if vendor in US_CLOSED:
        continue
    g[vendor].append(i)
if not g:
    sys.exit("no non-American no-thinking models found on the gateway")
for v in sorted(g):
    print(f"[{v}]")
    for i in sorted(g[v]):
        print(f"  {i}")
' || die "could not list models from ${BASE_URL} (tailscale up? gateway up?)"
      exit 0
    fi
    cat <<'MODELS'
claudim delegate aliases — curated best-in-class NON-AMERICAN (Chinese +
Mistral/France). US closed labs (openai, anthropic, google, x-ai, amazon,
nvidia, ibm-granite, liquid, rekaai, relace) are NEVER called. All no-thinking
(safe for `claude -p`).

  deepseek-v4-pro     smartest: heavy reasoning, multi-step logic, algorithms
  kimi-k2.7-code      coding: implement, refactor, bug fix, write tests
  deepseek-v4-flash   fastest/cheapest: triage, lookups, mechanical edits
  glm-5.2             long-context general: read/analyze big files, writing
  minimax-m3          long-context general alternative
  mistral-small       non-Chinese general (France): cheap, good for writing/analysis
  ministral-8b        non-Chinese cheapest (France): triage, lookups (alt to flash)
  codestral           non-Chinese coding (France): implement, refactor (alt to kimi)

Pick rule: use the CHEAPEST that can do the job; escalate to deepseek-v4-pro
only when the task needs real reasoning. Chinese or Mistral — your call per
task; both are cheap and non-American.

Delegate:  claudim -p --model <alias> "<task>"
JSON out:  claudim -p --output-format json --model <alias> "<task>"
gcloud/net: claudim -p --unrestricted --model <alias> "<task>"  # bypass perms
Watch live: CLAUDIM_TMUX=1 claudim -p --model <alias> "<task>"  # tmux window (in your session if you're inside tmux)
All non-American models live:  claudim models --all
A full routed id (contains "/") or a Claude alias (haiku/sonnet/opus) is
passed through unchanged.
MODELS
    exit 0
    ;;
esac

command -v claude >/dev/null 2>&1 || die "claude not found. Install: npm install -g @anthropic-ai/claude-code"
command -v tailscale >/dev/null 2>&1 || die "tailscale not found. Install Tailscale and log in to the jota.ai tailnet."

# Must be connected to the tailnet.
if ! tailscale status >/dev/null 2>&1; then
  die "not connected to the tailnet. Run 'tailscale up' (or open the Tailscale app) and retry."
fi

# Wait for the gateway to be reachable (it may be briefly unreachable; node could be asleep).
reachable() {
  if command -v nc >/dev/null 2>&1; then
    nc -z -w 3 "${FQDN}" "${PORT}" >/dev/null 2>&1
  else
    curl -s -o /dev/null -m 3 "${BASE_URL}/v1/models" -H "x-api-key: ${TOKEN}"
  fi
}

deadline=$(( $(date +%s) + WAIT ))
until reachable; do
  if [ "$(date +%s)" -ge "${deadline}" ]; then
    die "AI Gateway ${FQDN}:${PORT} not reachable within ${WAIT}s.
  Check: 'tailscale status' shows you connected and lists '${HOST}';
  the tailnet ACL permits you to reach tag:fcc-proxy on tcp:${PORT};
  the gateway is up (ask an admin). Override host/tailnet with CLAUDIM_HOST / CLAUDIM_TAILNET."
  fi
  sleep 1
done

export ANTHROPIC_BASE_URL="${BASE_URL}"
export ANTHROPIC_AUTH_TOKEN="${TOKEN}"
export CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1   # enables the /model picker

# High default; Claude Code clamps it to each model's real context window, so 1M
# ([1m]) models compact near 1M and smaller models clamp down to ~200K on their
# own. Lower it (or export in your shell) to force earlier compaction.
export CLAUDE_CODE_AUTO_COMPACT_WINDOW="${CLAUDE_CODE_AUTO_COMPACT_WINDOW:-1000000}"

# A parent Claude Code session (e.g. an Opus/Fable orchestrator on a real
# Anthropic subscription) may export ANTHROPIC_API_KEY. Claude Code gives that
# key precedence over ANTHROPIC_AUTH_TOKEN, so the child would auth against the
# gateway with the wrong credential and 401/hang. Drop it so the gateway token
# above is the sole auth source.
unset ANTHROPIC_API_KEY

say "gateway ${BASE_URL} — launching claude"

# Scan args once for: --model (rewrite to no-thinking id), --unrestricted
# (inject bypass-permissions so -p can run gcloud/network/writes), --tmux
# (wrap -p in a tmux window for live observation), and -p/--print (tmux only
# applies to print mode). Rebuild args only when one of claudim's own flags is
# present; otherwise pass through untouched (avoids empty-array expansion under
# `set -u` on bash 3.2).
has_model=0; has_unrestricted=0; has_tmux=0; has_print=0
for _a in "$@"; do
  case "$_a" in
    --model|--model=*) has_model=1 ;;
    --unrestricted) has_unrestricted=1 ;;
    --tmux) has_tmux=1 ;;
    -p|--print) has_print=1 ;;
  esac
done
if [ "${CLAUDIM_BYPASS:-0}" = "1" ]; then has_unrestricted=1; fi
if [ "${CLAUDIM_TMUX:-0}" = "1" ]; then has_tmux=1; fi
# Inside a tmux session, live panes are the DEFAULT for -p delegates — the
# orchestrator forgetting --tmux must not make a delegate invisible. Opt out
# with CLAUDIM_TMUX=0 (headless) when explicitly wanted.
if [ -n "${TMUX:-}" ] && [ "${CLAUDIM_TMUX:-}" != "0" ]; then has_tmux=1; fi

need_rebuild=0
if [ "${has_model}" -eq 1 ] || [ "${has_unrestricted}" -eq 1 ] || [ "${has_tmux}" -eq 1 ]; then
  need_rebuild=1
fi

if [ "${need_rebuild}" -eq 1 ]; then
  args=()
  # Bypass flags first (only when --unrestricted): let the -p delegate run
  # gcloud/GCP/network/file-writes the default `auto` mode denies non-interactively.
  if [ "${has_unrestricted}" -eq 1 ]; then
    args+=("--dangerously-skip-permissions" "--allow-dangerously-skip-permissions")
  fi
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --unrestricted|--tmux) shift ;;                 # claudim-only, stripped
      --model=*) args+=("--model=$(resolve_model_alias "${1#--model=}")"); shift ;;
      --model)
        args+=("--model"); shift
        [ "$#" -gt 0 ] && { args+=("$(resolve_model_alias "$1")"); shift; }
        ;;
      *) args+=("$1"); shift ;;
    esac
  done

  # Observation: tmux window per delegate. If the orchestrator session already
  # runs inside tmux ($TMUX set), the window opens in THAT session — visible
  # right where the user is, navigable (C-b n/p) and interactive. Outside tmux
  # it opens in a detached session `claudim` (tmux attach -t claudim). -p only.
  if [ "${has_tmux}" -eq 1 ] && [ "${has_print}" -eq 1 ]; then
    if command -v tmux >/dev/null 2>&1; then
      if [ -n "${TMUX:-}" ]; then
        say "tmux: delegate window opening in your current session (C-b n / C-b w)"
      else
        say "tmux: delegate in detached session (tmux attach -t claudim)"
      fi
      run_in_tmux "${args[@]}"
      exit 0
    fi
    say "tmux not found; running delegate inline (brew install tmux to observe)"
  elif [ "${has_tmux}" -eq 1 ]; then
    say "--tmux is for -p delegates only; ignoring"
  fi

  exec claude "${args[@]}"
fi

exec claude "$@"
